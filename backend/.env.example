# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Models
PARSER_MODEL=claude-haiku-4-5-20251001
CATEGORIZER_MODEL=claude-haiku-4-5-20251001
CHAT_MODEL=claude-sonnet-4-6

# Database
# Local dev: native Postgres on localhost:5432, with a `sente` database.
#   createdb sente
# psycopg2 picks up the OS user via libpq if no user is in the URL.
DATABASE_URL=postgresql+psycopg2://localhost:5432/sente
#
# Production: Supabase. Use the "Connection Pooling" string from
# Project Settings -> Database (Transaction mode, port 6543) and append
# ?sslmode=require. Example shape:
# DATABASE_URL=postgresql+psycopg2://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require

# Embeddings
EMBEDDING_MODEL=sentence-transformers/bge-small-en-v1.5

# App
CORS_ORIGINS=http://localhost:3000

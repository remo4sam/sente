# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Models
PARSER_MODEL=claude-haiku-4-5-20251001
CATEGORIZER_MODEL=claude-haiku-4-5-20251001
CHAT_MODEL=claude-sonnet-4-6

# Database
DATABASE_URL=sqlite:///./sente.db

# Embeddings
EMBEDDING_MODEL=sentence-transformers/bge-small-en-v1.5

# App
CORS_ORIGINS=http://localhost:3000

# LangSmith observability (optional — leave disabled if you don't have an account)
# When LANGSMITH_TRACING=true, every Anthropic call is traced to your project.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=sente

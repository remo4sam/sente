# Set this in Vercel project settings -> Environment Variables.
# Two options:
#   1. Direct backend URL:  https://your-backend.up.railway.app
#   2. Same-origin via Vercel rewrite:  /api  (and configure rewrites in vercel.json)

NEXT_PUBLIC_API_BASE=https://YOUR-BACKEND-URL.up.railway.app

# Clerk — auto-provisioned by the Vercel Marketplace integration; otherwise set manually.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxx
CLERK_SECRET_KEY=sk_live_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard
